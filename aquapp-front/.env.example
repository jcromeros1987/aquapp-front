# URL base del API Laravel (sin barra final).
# Se aplica al ejecutar: npm run build:prod
NG_API_URL=https://api.aquapp.com.mx/public/api

# Ruta pública donde colgarás el build (barra inicial; barra final recomendada).
# Raíz del subdominio: /
# Ej. archivos en public_html/aquapp-front/aquapp-front/ →
NG_BASE_HREF=/aquapp-front/aquapp-front/
